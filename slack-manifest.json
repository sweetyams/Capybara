{
  "display_information": {
    "name": "Capybara",
    "description": "Context-aware project assistant",
    "background_color": "#6366f1"
  },
  "features": {
    "bot_user": {
      "display_name": "Capybara",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:history",
        "channels:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://placeholder.example.com/api/slack/events",
      "bot_events": [
        "message.channels"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false
  }
}
